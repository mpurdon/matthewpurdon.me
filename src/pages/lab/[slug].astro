---
import { PROJECTS } from '../../data.js';
import { ogVersion } from '../../og-version.js';
import Layout from '../../layouts/Layout.astro';
import LabLayout from '../../layouts/LabLayout.astro';
import { ProjectDetail } from '../../lab.jsx';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  return PROJECTS.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

// Migration dual-source: render an MDX collection entry when one exists,
// otherwise fall back to the legacy React ProjectDetail.
const labEntries = await getCollection('lab');
const entry = labEntries.find((n) => n.id === project.slug);
const Content = entry ? (await render(entry)).Content : null;

const appSchema = {
  "@context": "https://schema.org",
  "@type": project.type === "Software" ? "SoftwareApplication" : "CreativeWork",
  "name": project.name,
  "description": project.tagline,
  "softwareRequirements": project.stack.join(", "),
  "downloadUrl": project.link
};

const SETTINGS = {
  hero: 'portrait',
  labStyle: 'cards',
  density: 'comfortable',
  covers: 'typographic',
  red: 'bold',
};
---

<Layout
  title={`${project.name} — Matthew Purdon · Lab`}
  description={project.tagline}
  ogImage={`/og/lab/${project.slug}.png?v=${ogVersion([project.name, project.type, project.tagline, project.accent, project.status])}`}
  view="lab"
  jsonLd={[appSchema]}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Lab Reports', path: '/lab' },
    { name: project.name, path: `/lab/${project.slug}` }
  ]}
>
  {Content ? (
    <LabLayout project={project}>
      <Content />
    </LabLayout>
  ) : (
    <ProjectDetail project={project} t={SETTINGS} client:load />
  )}
</Layout>
