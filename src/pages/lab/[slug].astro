---
import { getProjects } from '../../lib/content.js';
import { ogVersion } from '../../og-version.js';
import Layout from '../../layouts/Layout.astro';
import LabLayout from '../../layouts/LabLayout.astro';
import { getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

// Body comes from the MDX collection entry (one .mdx per slug).
const entry = await getEntry('lab', project.slug);
const { Content } = await render(entry);

const appSchema = {
  "@context": "https://schema.org",
  "@type": project.type === "Software" ? "SoftwareApplication" : "CreativeWork",
  "name": project.name,
  "description": project.tagline,
  "softwareRequirements": project.stack.join(", "),
  "downloadUrl": project.link
};
---

<Layout
  title={`${project.name} — Matthew Purdon · Lab`}
  description={project.tagline}
  ogImage={`/og/lab/${project.slug}.png?v=${ogVersion([project.name, project.type, project.tagline, project.accent, project.status])}`}
  view="lab"
  jsonLd={[appSchema]}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Lab Reports', path: '/lab' },
    { name: project.name, path: `/lab/${project.slug}` }
  ]}
>
  <LabLayout project={project}>
    <Content />
  </LabLayout>
</Layout>
