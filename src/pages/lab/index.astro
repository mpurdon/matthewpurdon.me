---
import Layout from '../../layouts/Layout.astro';
import { LabIndex } from '../../lab.jsx';

const SETTINGS = {
  hero: 'portrait',
  labStyle: 'cards',
  density: 'comfortable',
  covers: 'typographic',
  red: 'bold',
};
---

<Layout view="lab">
  <LabIndex
    t={SETTINGS}
    client:load
  />
</Layout>
