---
import { TOPICS } from '../../data.js';
import { getNotes } from '../../lib/content.js';
import Layout from '../../layouts/Layout.astro';
import { pad, LEAF } from '../../lib/ui.js';
import ArticleCard from '../../components/ArticleCard.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import TopicChip from '../../components/TopicChip.astro';

export async function getStaticPaths() {
  return Object.keys(TOPICS).map((topic) => ({
    params: { topic },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const t = {
  hero: 'portrait',
  labStyle: 'cards',
  density: 'comfortable',
  covers: 'typographic',
  red: 'bold',
};
const info = TOPICS[topic] || { blurb: 'Posts on this topic.', accent: 'amber' };
const allPosts = await getNotes();
const posts = allPosts.filter(p => p.tags.includes(topic) || p.category === topic);
const related = Object.keys(TOPICS).filter(x => x !== topic).slice(0, 6);

const pageTitle = `${topic} — Field Notes by Matthew Purdon`;
const pageDescription = info.blurb
  ? `${info.blurb} Explore articles and insights on ${topic.toLowerCase()} by principal engineer and AI platform builder Matthew Purdon.`
  : `Field Notes, articles, and thoughts on ${topic} by Matthew Purdon.`;

const topicJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": `https://matthewpurdon.me/topic/${encodeURIComponent(topic)}`,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": posts.length,
    "itemListElement": posts.map((p, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": `https://matthewpurdon.me/notes/${p.slug}/`,
      "name": p.title,
      "description": p.dek
    }))
  }
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  jsonLd={[topicJsonLd]}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Field Notes', path: '/notes' },
    { name: topic, path: `/topic/${encodeURIComponent(topic)}` }
  ]}
  view="notes"
>
  <main style="max-width:880px;margin:0 auto;padding:0 32px 96px">
    <header style={`padding:${pad(t, '56px 0 32px', '40px 0 26px')};border-bottom:1px solid var(--border)`}>
      <a href="/notes" style="font-family:var(--font-label);text-transform:uppercase;letter-spacing:var(--tracking-wider);font-size:var(--text-xs);font-weight:700;color:var(--text-muted);text-decoration:none">← All Field Notes</a>
      <div style="display:flex;align-items:center;gap:14px;margin:18px 0 12px">
        <svg width="30" height="30" viewBox="-2015 -2000 4030 4030" fill="currentColor" style="color:var(--canada-500);flex-shrink:0"><path d={LEAF} /></svg>
        <h1 style="font-family:var(--font-mono);font-weight:700;font-size:clamp(28px, 4vw, 44px);letter-spacing:-0.03em;margin:0;color:var(--text-primary)"><span style="color:var(--canada-300)">#</span>{topic}</h1>
      </div>
      <p style="font-family:var(--font-prose);font-size:var(--prose-lead);line-height:1.5;color:var(--text-secondary);max-width:600px;margin:0">{info.blurb}</p>

      {info.keyConcepts && (
        <div style="margin-top:22px">
          <p style="font-family:var(--font-label);text-transform:uppercase;letter-spacing:var(--tracking-widest);font-size:11px;font-weight:700;color:var(--text-muted);margin:0 0 10px">Core themes explored</p>
          <div style="display:flex;flex-wrap:wrap;gap:8px">
            {info.keyConcepts.map(c => (
              <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-secondary);padding:0.35rem 0.75rem;border-radius:var(--radius-md);border:1px solid var(--border);background:var(--bg-surface)">{c}</span>
            ))}
          </div>
        </div>
      )}

      <p style={`font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-muted);margin-top:${info.keyConcepts ? 24 : 14}px;text-transform:uppercase;letter-spacing:var(--tracking-wide)`}>{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
    </header>

    <section style="padding-top:8px">
      {posts.length > 0 && (
        <div style="margin-bottom:32px">
          <ArticleCard variant="hero" accent={posts[0].accent} category={posts[0].category} href={'/notes/' + posts[0].slug} title={posts[0].title} dek={posts[0].dek} date={posts[0].date} time={posts[0].time} big={posts[0].number} ratio="4 / 3" />
        </div>
      )}
      {posts.slice(1).map((p) => (
        <ArticleCard variant="list" category={p.category} href={'/notes/' + p.slug} title={p.title} dek={p.dek} date={p.date} time={p.time} />
      ))}
      {posts.length === 0 && <p style="font-family:var(--font-prose);color:var(--text-muted);padding:32px 0">No posts here yet — check back after the next one.</p>}
    </section>

    <section style="margin-top:48px;padding-top:28px;border-top:1px solid var(--border)">
      <SectionLabel style="margin-bottom:16px">Related topics</SectionLabel>
      <div style="display:flex;flex-wrap:wrap;gap:8px">
        {related.map(x => <TopicChip label={x} t={t} size="sm" />)}
      </div>
    </section>
  </main>
</Layout>
