---
import Layout from '../../layouts/Layout.astro';
import { NotesIndex } from '../../notes.jsx';

const SETTINGS = {
  hero: 'portrait',
  labStyle: 'cards',
  density: 'comfortable',
  covers: 'typographic',
  red: 'bold',
