---
import Layout from '../../layouts/Layout.astro';
import { NotesIndex } from '../../notes.jsx';
import { getNotes } from '../../lib/content.js';

const posts = await getNotes();

const notesSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Field Notes — Matthew Purdon",
  "description": "Essays and field notes by Matthew Purdon on AI-assisted engineering, code review, the new SDLC, and how teams actually ship.",
  "url": Astro.url.href,
  "publisher": {
    "@type": "Person",
    "name": "Matthew Purdon"
  }
};

const SETTINGS = {
  hero: 'portrait',
  labStyle: 'cards',
  density: 'comfortable',
  covers: 'typographic',
  red: 'bold',
};
---

<Layout
  title="Field Notes on AI-Assisted Engineering — Matthew Purdon"
  description="Essays and field notes by Matthew Purdon on AI-assisted engineering, code review, the new SDLC, and how teams actually ship."
  view="notes"
  jsonLd={[notesSchema]}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Field Notes', path: '/notes' }
  ]}
>
  <NotesIndex t={SETTINGS} posts={posts} />
</Layout>
