---
import { POSTS, postNumber } from '../../data.js';
import { ogVersion } from '../../og-version.js';
import Layout from '../../layouts/Layout.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleView from '../../article.jsx';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  return POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// Migration dual-source: render an MDX collection entry when one exists,
// otherwise fall back to the legacy React ArticleView. Chrome/OG metadata come
// from POSTS either way, so the OG cache-buster hash stays identical.
const notes = await getCollection('notes');
const entry = notes.find((n) => n.id === post.slug);
const Content = entry ? (await render(entry)).Content : null;
const publishedDate = new Date(post.dateLong || post.date).toISOString();
const modifiedDate = new Date(post.updatedLong || post.dateLong || post.date).toISOString();

const noteSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.dek,
  "datePublished": publishedDate,
  "dateModified": modifiedDate,
  "url": Astro.url.href,
  "articleSection": post.category,
  "keywords": post.tags,
  "inLanguage": "en-CA",
  "author": {
    "@type": "Person",
    "name": "Matthew Purdon",
    "url": "https://matthewpurdon.me/about/"
  },
  "isPartOf": {
    "@type": "Blog",
    "name": "Field Notes — Matthew Purdon",
    "url": "https://matthewpurdon.me/notes/"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};

const SETTINGS = {
  hero: 'portrait',
  labStyle: 'cards',
  density: 'comfortable',
  covers: 'typographic',
  red: 'bold',
};
---

<Layout
  title={`${post.title} — Matthew Purdon`}
  description={post.dek}
  ogType="article"
  ogImage={`/og/notes/${post.slug}.png?v=${ogVersion([post.title, post.category, post.dek, post.accent, post.time, postNumber(post)])}`}
  view="notes"
  jsonLd={[noteSchema]}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Field Notes', path: '/notes' },
    { name: post.title, path: `/notes/${post.slug}` }
  ]}
>
  {Content ? (
    <ArticleLayout post={post}>
      <Content />
    </ArticleLayout>
  ) : (
    <ArticleView post={post} t={SETTINGS} client:load />
  )}
</Layout>
