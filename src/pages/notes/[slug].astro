---
import { POSTS } from '../../data.js';
import Layout from '../../layouts/Layout.astro';
import ArticleView from '../../article.jsx';

export async function getStaticPaths() {
  return POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const publishedDate = new Date(post.dateLong || post.date).toISOString();
const modifiedDate = new Date(post.updatedLong || post.dateLong || post.date).toISOString();

const noteSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.dek,
  "datePublished": publishedDate,
  "dateModified": modifiedDate,
  "url": Astro.url.href,
  "articleSection": post.category,
  "keywords": post.tags,
  "inLanguage": "en-CA",
  "author": {
    "@type": "Person",
    "name": "Matthew Purdon",
    "url": "https://matthewpurdon.me/about/"
  },
  "isPartOf": {
    "@type": "Blog",
    "name": "Field Notes — Matthew Purdon",
    "url": "https://matthewpurdon.me/notes/"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};

const SETTINGS = {
  hero: 'portrait',
  labStyle: 'cards',
  density: 'comfortable',
  covers: 'typographic',
  red: 'bold',
};
---

<Layout
  title={`${post.title} — Matthew Purdon`}
  description={post.dek}
  ogType="article"
  ogImage={`/og/notes/${post.slug}.png`}
  view="notes"
  jsonLd={[noteSchema]}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Field Notes', path: '/notes' },
    { name: post.title, path: `/notes/${post.slug}` }
  ]}
>
  <ArticleView
    post={post}
    t={SETTINGS}
    client:load
  />
</Layout>
