---
import { getNotes } from '../../lib/content.js';
import { ogVersion } from '../../og-version.js';
import Layout from '../../layouts/Layout.astro';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getNotes();
  return notes.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// Body comes from the MDX collection entry (one .mdx per slug).
const entry = await getEntry('notes', post.slug);
const { Content } = await render(entry);
const publishedDate = new Date(post.dateLong || post.date).toISOString();
const modifiedDate = new Date(post.updatedLong || post.dateLong || post.date).toISOString();

const noteSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.dek,
  "datePublished": publishedDate,
  "dateModified": modifiedDate,
  "url": Astro.url.href,
  "articleSection": post.category,
  "keywords": post.tags,
  "inLanguage": "en-CA",
  "author": {
    "@type": "Person",
    "name": "Matthew Purdon",
    "url": "https://matthewpurdon.me/about/"
  },
  "isPartOf": {
    "@type": "Blog",
    "name": "Field Notes — Matthew Purdon",
    "url": "https://matthewpurdon.me/notes/"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};
---

<Layout
  title={`${post.title} — Matthew Purdon`}
  description={post.dek}
  ogType="article"
  ogImage={`/og/notes/${post.slug}.png?v=${ogVersion([post.title, post.category, post.dek, post.accent, post.time, post.number])}`}
  view="notes"
  jsonLd={[noteSchema]}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Field Notes', path: '/notes' },
    { name: post.title, path: `/notes/${post.slug}` }
  ]}
>
  <ArticleLayout post={post}>
    <Content />
  </ArticleLayout>
</Layout>
