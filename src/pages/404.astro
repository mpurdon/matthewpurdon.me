---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page not found — Matthew Purdon" description="This page does not exist.">
  <main style="max-width:640px;margin:0 auto;padding:96px 24px;text-align:center">
    <div style="font-family:var(--font-mono);font-size:clamp(48px, 8vw, 72px);font-weight:700;letter-spacing:-0.04em;color:var(--canada-500);line-height:1">404</div>
    <h1 style="margin:18px 0 10px;font-family:var(--font-mono);font-size:clamp(20px, 3vw, 26px);letter-spacing:-0.025em;color:var(--text-primary)">Page not found</h1>
    <p style="margin:0 0 28px;font-family:var(--font-prose);color:var(--text-secondary);line-height:1.6">
      Whatever was supposed to be here got shelved. It happens to the best ideas.
    </p>
    <a href="/" style="font-family:var(--font-label);font-size:13px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--canada-300);text-decoration:none">Back to the homepage →</a>
  </main>
</Layout>
