---
import Layout from '../layouts/Layout.astro';
import AboutView from '../about.jsx';

const SETTINGS = {
  hero: 'portrait',
  labStyle: 'cards',
  density: 'comfortable',
  covers: 'typographic',
  red: 'bold',
};

const profileSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "url": Astro.url.href,
  "mainEntity": {
    "@type": "Person",
    "name": "Matthew Purdon",
    "jobTitle": "Principal Engineer & AI Platform Builder",
    "url": Astro.url.href,
    "image": "https://matthewpurdon.me/images/matthew-purdon.webp",
    "sameAs": [
      "https://github.com/mpurdon",
      "https://www.linkedin.com/in/matthewdjpurdon",
      "https://x.com/mpurdon"
    ]
  }
};
---

<Layout
  title="About Matthew Purdon — Principal Engineer & AI Platform Builder"
  description="About Matthew Purdon, principal engineer and AI platform builder in Toronto with twenty-five years of experience turning messy software delivery into repeatable systems."
  view="about"
  jsonLd={[profileSchema]}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'About', path: '/about' }
  ]}
>
  <AboutView t={SETTINGS} />
</Layout>
