---
/* Chrome for a single Field Note: header (category kicker, title, dek, byline),
   cover, the MDX body (slotted into the mp-prose container), filed-under tags,
   and the author bio. Replaces the former React ArticleView (article.jsx). The
   body is passed in via <slot/>; the page (notes/[slug].astro) renders the MDX
   <Content/> into it. Zero-JS except the hoisted deep-anchors script below. */
import DS from '../ds/index.js';
import { Cover } from '../shared.jsx';
import { AVATAR, PROFILE } from '../data.js';
import DeepAnchors from '../components/DeepAnchors.astro';
const { Byline } = DS;
const { post } = Astro.props;
---
<main>
  <article>
    <header style="max-width:820px;margin:0 auto;padding:56px 32px 32px;text-align:center">
      <a
        href={`/topic/${encodeURIComponent(post.category)}`}
        style="font-family:var(--font-label);text-transform:uppercase;letter-spacing:var(--tracking-wider);font-size:var(--text-xs);font-weight:700;color:var(--canada-300);text-decoration:none"
      >← {post.category}</a>
      <h1 style="font-family:var(--font-mono);font-weight:700;font-size:clamp(30px, 4.4vw, 50px);line-height:1.08;letter-spacing:-0.03em;margin:18px 0 20px;color:var(--text-primary);text-wrap:balance">{post.title}</h1>
      <p style="font-family:var(--font-prose);font-size:var(--prose-lead);line-height:1.5;color:var(--text-secondary);max-width:640px;margin:0 auto 28px;text-wrap:pretty">{post.dek}</p>
      <div style="display:flex;justify-content:center">
        <Byline author="Matthew Purdon" avatar="MP" date={post.dateLong || post.date} readingTime={post.time} tag={post.category} />
      </div>
    </header>

    <div style="max-width:1080px;margin:0 auto 8px;padding:0 32px">
      <Cover category={post.category} accent={post.accent} height={60} labelSize="var(--prose-lead)" centerLabel />
    </div>

    <div class="article-body" style="max-width:760px;margin:0 auto;padding:32px 32px 64px">
      <div class="mp-prose mp-prose--dropcap" style="max-width:100%">
        <slot />
      </div>

      <div style="margin-top:36px;display:flex;flex-wrap:wrap;gap:8px;align-items:center">
        <span style="font-family:var(--font-label);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:var(--tracking-wider);color:var(--text-muted);margin-inline-end:4px">Filed under</span>
        {post.tags.map((tag) => (
          <a
            href={`/topic/${encodeURIComponent(tag)}`}
            style="display:inline-flex;align-items:center;gap:0.35rem;font-family:var(--font-mono);font-size:var(--text-xs);color:var(--canada-300);text-decoration:none;padding:0.3rem 0.7rem;border-radius:var(--radius-full);border:1px solid rgba(213,43,30,0.32);background:rgba(213,43,30,0.08)"
          >#{tag}</a>
        ))}
      </div>

      <div style="margin-top:48px;padding-top:28px;border-top:1px solid var(--border);display:flex;gap:16px;align-items:flex-start">
        <img
          src={AVATAR}
          alt="Matthew Purdon"
          width="48"
          height="48"
          style="width:48px;height:48px;border-radius:9999px;object-fit:cover;flex-shrink:0;border:1px solid var(--border-strong)"
        />
        <div>
          <p style="font-family:var(--font-mono);font-weight:600;font-size:var(--text-sm);color:var(--text-primary);margin:0">Matthew Purdon</p>
          <p style="font-family:var(--font-prose);font-size:var(--text-base);line-height:1.6;color:var(--text-secondary);margin:6px 0 10px;max-width:520px">
            Principal engineer and AI platform builder in Toronto with twenty-five years of experience turning messy
            software delivery into repeatable systems. Writes Field Notes on AI-assisted engineering and the new SDLC,
            and builds tools and processes in the Lab Reports.
          </p>
          <div style="display:flex;gap:14px">
            <a href="/about" style="font-family:var(--font-mono);font-size:var(--text-sm);color:var(--canada-300);text-decoration:none">About →</a>
            <a href={PROFILE.links.github} target="_blank" rel="noopener noreferrer" style="font-family:var(--font-mono);font-size:var(--text-sm);color:var(--text-muted);text-decoration:none">GitHub ↗</a>
          </div>
        </div>
      </div>
    </div>
  </article>
</main>

<DeepAnchors />
