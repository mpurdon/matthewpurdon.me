---
/* Chrome for a single Lab report: back link, type/AI badges, name, tagline, the
   meta row (type/status/date/AI), the MDX body (slotted into the mp-prose
   container), the stack pills, the source link, and "More Lab Reports".
   Replaces the former React ProjectDetail (lab.jsx). Zero-JS except the shared
   deep-anchors script. */
import { TypeBadge, AIBadge, TYPE_META } from '../shared.jsx';
import { getProjects } from '../lib/content.js';
import DeepAnchors from '../components/DeepAnchors.astro';

const { project: pr } = Astro.props;
const others = (await getProjects()).filter((x) => x.slug !== pr.slug).slice(0, 3);
const meta = [
  ['Type', pr.type],
  ['Status', pr.status],
  pr.date ? ['Date', pr.date] : ['Year', pr.year],
  ['AI partner', pr.ai ? 'Yes' : 'No'],
];
---
<main style="max-width:820px;margin:0 auto;padding:0 32px 96px">
  <header style="padding:56px 0 28px">
    <a href="/lab" style="font-family:var(--font-label);text-transform:uppercase;letter-spacing:var(--tracking-wider);font-size:var(--text-xs);font-weight:700;color:var(--text-muted);text-decoration:none">← Lab Reports</a>
    <div style="display:flex;gap:8px;margin:20px 0 16px"><TypeBadge type={pr.type} />{pr.ai && <AIBadge />}</div>
    <h1 style="font-family:var(--font-mono);font-weight:700;font-size:clamp(30px, 4.4vw, 48px);line-height:1.06;letter-spacing:-0.03em;margin:0 0 18px;color:var(--text-primary);text-wrap:balance">{pr.name}</h1>
    <p style="font-family:var(--font-prose);font-size:var(--prose-lead);line-height:1.5;color:var(--text-secondary);max-width:640px;margin:0">{pr.tagline}</p>
  </header>

  <div style="display:flex;flex-wrap:wrap;gap:28px;padding:22px 0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin-bottom:8px">
    {meta.map(([k, v]) => (
      <div>
        <p style="font-family:var(--font-label);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:var(--tracking-wide);color:var(--text-muted);margin:0 0 5px">{k}</p>
        <p style="font-family:var(--font-mono);font-size:var(--text-base);color:var(--text-primary);margin:0">{v}</p>
      </div>
    ))}
  </div>

  <div class="article-body" style="padding:28px 0 8px">
    <div class="mp-prose" style="max-width:100%">
      <slot />
    </div>
    <div style="margin:26px 0">
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        {pr.stack.map((s) => (
          <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-muted);padding:0.2rem 0.55rem;border-radius:var(--radius-sm);border:1px solid var(--border)">{s}</span>
        ))}
      </div>
    </div>
    <a href={pr.link} target="_blank" rel="noopener noreferrer" class="mp-btn mp-btn--solid mp-btn--md" style="text-decoration:none">{pr.linkLabel} ↗</a>
  </div>

  <section style="margin-top:48px;padding-top:28px;border-top:1px solid var(--border)">
    <p style="font-family:var(--font-label);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:var(--tracking-wider);color:var(--text-muted);margin:0 0 16px">More Lab Reports</p>
    <div>
      {others.map((o, i) => {
        const m = TYPE_META[o.type] || TYPE_META.Software;
        return (
          <a href={'/lab/' + o.slug} style={`display:flex;align-items:center;gap:14px;text-decoration:none;padding:14px 0;border-top:${i === 0 ? 'none' : '1px solid var(--border)'}`}>
            <span style={`width:8px;height:8px;border-radius:9999px;background:${m.dot};flex-shrink:0`} />
            <span style="font-family:var(--font-mono);font-weight:600;font-size:var(--text-base);color:var(--text-primary)">{o.name}</span>
            <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-muted);margin-left:auto">{o.type}</span>
          </a>
        );
      })}
    </div>
  </section>
</main>

<DeepAnchors />
