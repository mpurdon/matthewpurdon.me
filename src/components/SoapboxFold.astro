---
/* Collapsed-by-default Soapbox for end-of-article rants. Native <details> so it
   opens with ZERO JavaScript (the old React version needed hydration to open).
   The <summary> carries the "Soapbox" eyebrow + title; the DS Soapbox renders
   the body, its own header hidden via `.soap-fold .mp-soap__head { display:none }`
   in site.css. See also the .soap-fold[open] rules there for the CTA text swap. */
import DS from '../ds/index.js';
import { LEAF } from '../lib/ui.js';
const { Soapbox } = DS;
const { title, signoff } = Astro.props;
---
<details
  class="soap-fold"
  style="border:1px solid rgba(213,43,30,0.35);border-inline-start:4px solid var(--canada-500);border-radius:var(--radius-lg);background:var(--callout-soapbox-bg);overflow:hidden;"
>
  <summary
    class="soap-fold__head"
    style="padding:1.05rem 1.5rem;background-image:linear-gradient(180deg, rgba(213,43,30,0.10), rgba(213,43,30,0));"
  >
    <span style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;flex-wrap:wrap;">
      <span style="display:inline-flex;align-items:center;gap:0.45rem;font-family:var(--font-label);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:var(--tracking-widest);color:var(--canada-300);">
        <svg width="12" height="12" viewBox="-2015 -2000 4030 4030" fill="currentColor" aria-hidden="true" style="color:var(--canada-400);flex-shrink:0;"><path d={LEAF} /></svg>
        Soapbox
      </span>
      <span class="soap-fold__cta" style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--text-muted);"></span>
    </span>
    <span style="display:block;margin-top:8px;font-family:var(--font-mono);font-weight:700;font-size:1.15rem;letter-spacing:-0.01em;color:var(--text-primary);">{title}</span>
  </summary>
  <Soapbox title={title} signoff={signoff}>
    <slot />
  </Soapbox>
</details>
