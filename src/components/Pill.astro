---
const { color, bg, border } = Astro.props;
---
<span style={`display:inline-flex;align-items:center;gap:0.4rem;font-family:var(--font-label);font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:var(--tracking-wide);padding:0.25rem 0.6rem;border-radius:var(--radius-full);color:${color || 'var(--text-secondary)'};background:${bg || 'transparent'};border:${border || '1px solid var(--border)'}`}><slot /></span>
